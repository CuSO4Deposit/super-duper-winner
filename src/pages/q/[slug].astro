---
import QuoteMeta from "../../components/QuoteMeta.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getAllQuotes,
  getHomePath,
  type QuoteRecord,
} from "../../lib/quotes";

type Props = {
  quote: QuoteRecord;
};

export async function getStaticPaths() {
  const quotes = await getAllQuotes();

  return quotes.map((quote) => ({
    params: { slug: quote.slug },
    props: { quote },
  }));
}

const { quote }: Props = Astro.props;
const pageTitle = `${quote.speaker} | Quotations`;
---

<BaseLayout title={pageTitle}>
  <div class="page-shell page-shell-detail detail-page">
    <SiteHeader />

    <article class="detail-article">
      <h1 class="detail-title">Quote from {quote.speaker}</h1>

      <blockquote class="detail-body">
        <p>{quote.body}</p>
      </blockquote>

      <QuoteMeta
        time={quote.time}
        renderedTime={quote.renderedTime}
        speaker={quote.speaker}
        source={quote.source}
        tags={quote.tags}
      />

      <p class="detail-back">
        <a href={getHomePath()}>Back to archive</a>
      </p>
    </article>
  </div>
</BaseLayout>
