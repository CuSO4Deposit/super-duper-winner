---
import { getTagPath, type QuoteRecord } from "../lib/quotes";

type Props = Pick<
  QuoteRecord,
  "time" | "renderedTime" | "speaker" | "source" | "tags"
>;

const { time, renderedTime, speaker, source, tags }: Props = Astro.props;
---

<div class="quote-meta">
  <p class="quote-meta-line">
    <time class="quote-meta-item" datetime={time}>{renderedTime}</time>
    <span class="quote-meta-separator" aria-hidden="true">·</span>
    <span class="quote-meta-item">{speaker}</span>
    <span class="quote-meta-separator" aria-hidden="true">·</span>
    <cite class="quote-meta-item quote-source">{source}</cite>
  </p>

  {
    tags.length > 0 && (
      <ul class="tag-list" aria-label="Tags">
        {tags.map((tag) => (
          <li>
            <a class="tag-link" href={getTagPath(tag)}>
              #{tag}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</div>
