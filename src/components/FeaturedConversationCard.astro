---
import {
  getConversationPath,
  getTagPath,
  type FeaturedConversationRecord,
} from "../lib/conversations";

import SpeakerAvatar from "./SpeakerAvatar.astro";

type Props = {
  conversation: FeaturedConversationRecord;
};

const { conversation }: Props = Astro.props;
const { featuredMessage } = conversation;
---

<article class="featured-card">
  <a class="featured-card-link" href={getConversationPath(conversation.slug)}>
    <div class="featured-card-speaker">
      <SpeakerAvatar
        src={featuredMessage.speaker.avatar}
        alt={featuredMessage.speaker.name}
        size="sm"
      />
      <span class="featured-card-name">{featuredMessage.speaker.name}</span>
    </div>

    <blockquote class="featured-card-body">
      <p>{featuredMessage.text}</p>
    </blockquote>

    <span class="featured-card-link-label" aria-hidden="true">Open thread</span>
  </a>

  <div class="featured-card-meta">
    <p class="featured-card-meta-line">
      <time datetime={featuredMessage.time}>{featuredMessage.renderedTime}</time>
      <span class="featured-card-meta-separator" aria-hidden="true">·</span>
      <cite>{conversation.source}</cite>
    </p>

    {
      conversation.tags.length > 0 && (
        <ul class="tag-list" aria-label="Tags">
          {conversation.tags.map((tag) => (
            <li>
              <a class="tag-link" href={getTagPath(tag)}>
                #{tag}
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>
